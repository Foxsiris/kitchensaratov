# Скопируйте в server/.env — Prisma CLI и Studio подхватят DATABASE_URL автоматически.
# Postgres должен быть доступен с вашей машины (docker-compose пробрасывает 127.0.0.1:15432).
#
# Пароль — тот же, что POSTGRES_PASSWORD в корневом .env (не ADMIN_PASSWORD).

DATABASE_URL="postgresql://kitchensaratov:kitchensaratov@127.0.0.1:15432/kitchensaratov?schema=public"

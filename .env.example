# Скопируйте в .env и подставьте значения для docker compose / сервера.

# Если обновили начальную миграцию Prisma (init) и схема не совпадает с данными:
#   docker compose down -v && docker compose up -d --build
# Локально: из каталога server — npx prisma migrate reset (данные каталога будут удалены).

# --- PostgreSQL (сервис db) ---
POSTGRES_USER=kitchensaratov
POSTGRES_PASSWORD=задайте_надёжный_пароль
POSTGRES_DB=kitchensaratov
# Порт на localhost для Prisma Studio / DBeaver (docker-compose пробрасывает 127.0.0.1:PORT → 5432 в контейнере)
POSTGRES_PORT=15432

# --- API ---
# Секрет подписи JWT (например: openssl rand -hex 32)
JWT_SECRET=замените_на_случайную_строку

# Первый администратор (создаётся seed-скриптом, если таблица пуста)
ADMIN_EMAIL=admin@kitchensaratov.local
ADMIN_PASSWORD=changeme

# Смена пароля уже созданного админа (из корня репозитория, контейнер api запущен):
# docker compose exec api node scripts/set-admin-password.mjs новый_пароль

# --- Публикация сайта ---
HTTP_PORT=8080

# --- Локальная разработка фронтенда (без Docker) ---
# В package.json уже указан proxy на http://localhost:4000 — API должно слушать порт 4000.
# DATABASE_URL для Prisma Studio / CLI, если Postgres в Docker с проброшенным портом (см. POSTGRES_PORT):
# DATABASE_URL=postgresql://kitchensaratov:ПАРОЛЬ_КАК_В_POSTGRES_PASSWORD@127.0.0.1:15432/kitchensaratov?schema=public